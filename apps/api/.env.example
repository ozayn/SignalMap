# Postgres connection (required for Wayback jobs)
# Local: postgresql://localhost/signalmap
# Railway: set automatically when you add Postgres
DATABASE_URL=postgresql://localhost/signalmap

# YouTube Data API v3 (optional; for channel snapshots: subscriber/view/video counts)
# Get a key at https://console.cloud.google.com/apis/credentials (no real key in repo)
# YOUTUBE_API_KEY=

# Optional: restrict who can trigger live YouTube API calls. When set, only requests that send
# header X-Youtube-Api-Secret: <this value> can use live channel data (cache-first when cache miss, or POST jobs).
# Leave unset to allow anyone to trigger live calls.
# YOUTUBE_API_ALLOWED_SECRET=

# Set to 1 to disable the secret check (e.g. for local testing). Re-enable by removing or setting to 0.
# YOUTUBE_API_SECRET_CHECK_DISABLED=1
