# Set to 1 to log cache hit/miss, bundle_ms, and JSON bytes for dutch_disease_diagnostics_iran (API logs).
# SIGNAL_TIMING_LOG=1

# Postgres connection (required for Wayback jobs)
# Local: postgresql://localhost/signalmap
# Railway: set automatically when you add Postgres
DATABASE_URL=postgresql://localhost/signalmap

# EIA API (optional; for oil production - USA, Saudi, Russia, Iran). Fallback: FRED + static.
# Get a key at https://www.eia.gov/opendata/
# EIA_API_KEY=

# YouTube Data API v3 (optional; for channel snapshots: subscriber/view/video counts)
# Get a key at https://console.cloud.google.com/apis/credentials (no real key in repo)
# YOUTUBE_API_KEY=

# Optional: proxy for youtube-transcript-api (caption fetch). On Railway, set if YouTube blocks the host IP.
# Webshare rotating residential (preferred when both are set):
# WEBSHARE_PROXY_USER=
# WEBSHARE_PROXY_PW=
# Or a single HTTPS proxy URL (e.g. https://user:pass@host:port):
# YOUTUBE_PROXY_URL=

# Transcript language: try these caption codes in order (default: en). Comma- or space-separated.
# YOUTUBE_TRANSCRIPT_LANGUAGES=en

# If true (default), when no requested language exists, use the first available caption (manual before auto).
# Set to false to require a requested language (returns 422 with available_languages when mismatch).
# YOUTUBE_TRANSCRIPT_LANGUAGE_FALLBACK=true

# Optional: restrict who can trigger live YouTube API calls. When set, only requests that send
# header X-Youtube-Api-Secret: <this value> can use live channel data (cache-first when cache miss, or POST jobs).
# Leave unset to allow anyone to trigger live calls.
# YOUTUBE_API_ALLOWED_SECRET=

# Set to 1 to disable the secret check (e.g. for local testing). Re-enable by removing or setting to 0.
# YOUTUBE_API_SECRET_CHECK_DISABLED=1

# UN Comtrade API (optional; for oil trade network - bilateral crude oil flows HS 2709)
# Get a subscription key at https://comtradeplus.un.org/ or https://comtradedeveloper.un.org/
# COMTRADE_API_KEY= or COMTRADE_SUBSCRIPTION_KEY=

# Financial Modeling Prep (optional; for current Brent market price on study 2)
# Get a key at https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=

# Groq (optional; for summarize_llm, speaker_guess_llm, and fallacies with method=llm)
# https://console.groq.com/
# GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=
# Fallacy LLM per-chunk mode — default: llama-3.3-70b-versatile (override below).
# Alternatives sometimes used for structured JSON reliability: openai/gpt-oss-20b, openai/gpt-oss-120b
# Summarize-only: max transcript characters per single Groq request (default 12000).
# GROQ_SUMMARY_MAX_INPUT_CHARS=12000
# GROQ_FALLACY_MODEL=
# Temporary: log raw Groq JSON + normalization for fallacy chunks (see llm_transcript_analysis.py)
# GROQ_FALLACY_LLM_DEBUG=1
