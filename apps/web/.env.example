# Local: API runs on localhost:8000 (default in next.config)
# Railway: MUST set API_URL on web service, e.g.:
#   API_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}
#   or API_URL=https://your-api.up.railway.app

# Optional — donation / support page (Ko-fi, GitHub Sponsors, etc.). If unset, support links use the public repo URL.
# NEXT_PUBLIC_SIGNALMAP_SUPPORT_URL=

# Google Analytics 4. Use NEXT_PUBLIC_ prefix for Vercel/Railway.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Set to "true" to enable GA4 DebugView (events show in Admin > DebugView)
# NEXT_PUBLIC_GA_DEBUG=true

# Optional — Next.js Server Actions encryption (self-hosting / multiple instances).
# Same key at build time keeps action encryption stable across deploys; see Next.js doc
# "failed-to-find-server-action". Value: base64 encoding 16, 24, or 32 raw bytes (AES key length).
# Example: openssl rand -base64 32
# Set on Railway for the web service at build (and runtime if your pipeline requires it).
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
