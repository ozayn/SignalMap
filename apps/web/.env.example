# Local: API runs on localhost:8000 (default in next.config)
# Railway: MUST set API_URL on web service, e.g.:
#   API_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}
#   or API_URL=https://your-api.up.railway.app

# Google Analytics 4. Use NEXT_PUBLIC_ prefix for Vercel/Railway.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Set to "true" to enable GA4 DebugView (events show in Admin > DebugView)
# NEXT_PUBLIC_GA_DEBUG=true

# Optional (Next.js self-hosting): stable Server Action encryption across builds/instances.
# Use only if Next logs implicate key skew; value must be base64 with AES length 16/24/32 bytes.
# Generate e.g. `openssl rand -base64 32` — set in Railway for **build** and **runtime** if needed.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
